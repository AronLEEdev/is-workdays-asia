DATABASE_URL=postgresql://user:password@localhost:5432/isworkday
REDIS_URL=redis://localhost:6379

# Session signing secret — generate with: openssl rand -base64 32
NUXT_SESSION_PASSWORD=your-32-char-minimum-secret-here

# GitHub OAuth app (create at https://github.com/settings/developers)
NUXT_OAUTH_GITHUB_CLIENT_ID=your-github-client-id
NUXT_OAUTH_GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth app (create at https://console.cloud.google.com)
NUXT_OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret

# A real API key used server-side for the public landing page demo
NUXT_DEMO_API_KEY=isk_your_demo_key_here
